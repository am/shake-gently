{
  "body": {
    "display": "block",
    "flex-direction": "row",
    "min-height": "720px",
    "background-color": "rgb(5, 5, 5)",
    "font-family": "\"DM Sans\", sans-serif",
    "font-size": "16px",
    "font-weight": "400",
    "overflow": "hidden",
    "position": "static",
    "flex": "0 1 auto",
    "box-sizing": "border-box",
    "flex-wrap": "nowrap"
  },
  "#app": {
    "display": "flex",
    "flex-direction": "column",
    "padding": "0px 32px",
    "max-width": "960px",
    "background-color": "rgba(0, 0, 0, 0)",
    "font-family": "\"DM Sans\", sans-serif",
    "font-size": "16px",
    "font-weight": "400",
    "overflow": "visible",
    "position": "static",
    "flex": "0 1 auto",
    "box-sizing": "border-box",
    "flex-wrap": "nowrap"
  },
  ".chrome": {
    "display": "flex",
    "flex-direction": "row",
    "align-items": "center",
    "justify-content": "space-between",
    "padding": "18px 0px 14px",
    "background-color": "rgba(0, 0, 0, 0)",
    "font-family": "\"DM Sans\", sans-serif",
    "font-size": "16px",
    "font-weight": "400",
    "overflow": "visible",
    "position": "static",
    "flex": "0 1 auto",
    "box-sizing": "border-box",
    "flex-wrap": "nowrap"
  },
  ".status": {
    "display": "flex",
    "flex-direction": "row",
    "align-items": "center",
    "gap": "7px",
    "background-color": "rgba(0, 0, 0, 0)",
    "font-family": "\"DM Sans\", sans-serif",
    "font-size": "11px",
    "font-weight": "400",
    "letter-spacing": "0.88px",
    "text-transform": "uppercase",
    "overflow": "visible",
    "position": "static",
    "flex": "0 1 auto",
    "box-sizing": "border-box",
    "flex-wrap": "nowrap"
  },
  ".status-dot": {
    "display": "block",
    "flex-direction": "row",
    "background-color": "rgb(102, 102, 102)",
    "font-family": "\"DM Sans\", sans-serif",
    "font-size": "11px",
    "font-weight": "400",
    "letter-spacing": "0.88px",
    "text-transform": "uppercase",
    "border-radius": "50%",
    "overflow": "visible",
    "position": "static",
    "flex": "0 1 auto",
    "box-sizing": "border-box",
    "flex-wrap": "nowrap"
  },
  "main": {
    "display": "block",
    "flex-direction": "row",
    "padding": "0px 0px 16px",
    "background-color": "rgba(0, 0, 0, 0)",
    "font-family": "\"DM Sans\", sans-serif",
    "font-size": "16px",
    "font-weight": "400",
    "overflow": "visible",
    "position": "static",
    "flex": "1 1 0%",
    "box-sizing": "border-box",
    "flex-wrap": "nowrap"
  },
  "#editor-wrap": {
    "display": "block",
    "flex-direction": "row",
    "background-color": "rgba(0, 0, 0, 0)",
    "font-family": "\"DM Sans\", sans-serif",
    "font-size": "16px",
    "font-weight": "400",
    "border-radius": "16px",
    "overflow": "hidden",
    "position": "relative",
    "flex": "0 1 auto",
    "box-sizing": "border-box",
    "flex-wrap": "nowrap"
  },
  "#editor": {
    "display": "block",
    "flex-direction": "row",
    "background-color": "rgba(255, 255, 255, 0.024)",
    "font-family": "\"DM Sans\", sans-serif",
    "font-size": "16px",
    "font-weight": "400",
    "overflow": "visible",
    "position": "static",
    "backdrop-filter": "blur(40px)",
    "flex": "0 1 auto",
    "box-sizing": "border-box",
    "flex-wrap": "nowrap"
  },
  "#editor .cm-editor": {
    "display": "flex",
    "flex-direction": "column",
    "background-color": "rgba(0, 0, 0, 0)",
    "font-family": "\"DM Sans\", sans-serif",
    "font-size": "16px",
    "font-weight": "400",
    "overflow": "visible",
    "position": "relative",
    "flex": "0 1 auto",
    "box-sizing": "border-box",
    "flex-wrap": "nowrap"
  },
  "#editor .cm-scroller": {
    "display": "flex",
    "flex-direction": "row",
    "align-items": "flex-start",
    "padding": "24px 32px",
    "background-color": "rgba(0, 0, 0, 0)",
    "font-family": "monospace",
    "font-size": "13px",
    "font-weight": "400",
    "position": "relative",
    "flex": "0 1 auto",
    "box-sizing": "border-box",
    "line-height": "18.2px",
    "flex-wrap": "nowrap"
  },
  "#editor .cm-content": {
    "display": "block",
    "flex-direction": "row",
    "padding": "8px 0px",
    "min-height": "100%",
    "background-color": "rgba(0, 0, 0, 0)",
    "font-family": "\"Major Mono Display\", monospace",
    "font-size": "24px",
    "font-weight": "700",
    "overflow": "visible",
    "position": "static",
    "flex": "2 0 auto",
    "box-sizing": "border-box",
    "line-height": "36px",
    "flex-wrap": "nowrap"
  },
  "footer": {
    "display": "block",
    "flex-direction": "row",
    "padding": "12px 0px",
    "background-color": "rgba(0, 0, 0, 0)",
    "font-family": "\"DM Sans\", sans-serif",
    "font-size": "16px",
    "font-weight": "400",
    "overflow": "visible",
    "position": "static",
    "flex": "0 1 auto",
    "box-sizing": "border-box",
    "flex-wrap": "nowrap"
  },
  "#presence": {
    "display": "flex",
    "flex-direction": "row",
    "align-items": "center",
    "justify-content": "center",
    "gap": "16px",
    "background-color": "rgba(0, 0, 0, 0)",
    "font-family": "\"DM Sans\", sans-serif",
    "font-size": "16px",
    "font-weight": "400",
    "overflow": "visible",
    "position": "static",
    "flex": "0 1 auto",
    "box-sizing": "border-box",
    "flex-wrap": "wrap"
  }
}